# Internal/proprietary docs - NEVER commit
docs/internal/

# Training logs - experimental notes, not for public repo
docs/training_logs/

# Production data exports - NEVER commit
data/raw/*
!data/raw/.gitkeep
!data/raw/synthetic_*.json
!data/raw/synthetic*.jsonl

# Real-world / proprietary data — NEVER commit under any name or path
**/ner_export*.json
**/production_*.json
**/real_data*
**/export_*.json

# prod-secret folders — proprietary data, NEVER commit
**/prod-secret/*
!**/prod-secret/.gitkeep

# Processed datasets - too large for git
data/processed/*
!data/processed/.gitkeep

# HuggingFace dataset build output
data/hf_dataset/

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg
venv/
.venv/

# Environment & secrets
.env
.env.local
credentials.json

# Model artifacts (too large for git)
*.safetensors
*.bin
*.pt
*.pth
*.onnx
results/
results_v*/
checkpoints/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Jupyter
.ipynb_checkpoints/

# Weights & Biases
wandb/
